{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Musubi M1 Message Envelope",
  "type": "object",
  "required": ["message_id", "workspace_id", "app_id", "device_id", "channel", "created_at", "expires_at", "crypto", "ciphertext"],
  "properties": {
    "message_id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "app_id": { "type": "string" },
    "device_id": { "type": "string" },
    "channel": { "type": "string" },
    "created_at": { "type": "string" },
    "expires_at": { "type": "string" },
    "visible_metadata": { "type": "object" },
    "crypto": {
      "type": "object",
      "required": ["version", "alg", "sender_key_id", "recipient_key_id"],
      "properties": {
        "version": { "type": "string", "enum": ["m1"] },
        "alg": { "type": "string", "enum": ["x25519-xsalsa20-poly1305", "x25519-aes-256-gcm"] },
        "sender_key_id": { "type": "string" },
        "recipient_key_id": { "type": "string" }
      }
    },
    "ciphertext": { "type": "string" }
  }
}
