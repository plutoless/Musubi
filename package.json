{
  "name": "musubi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "server": "bun run apps/relay-server/src/main.ts",
    "app:echo": "bun run apps/app-simulator/src/main.ts echo.echo",
    "app:denied": "bun run apps/app-simulator/src/main.ts shell.run",
    "db:migrate:neon": "bun run tools/apply_neon_migrations.ts",
    "verify": "bun run tools/verify.ts",
    "verify:go": "MUSUBI_VERIFY_DEVICE=go bun run tools/verify.ts",
    "verify:m1-contracts": "bun run tools/verify_m1_contracts.ts",
    "verify:slice1": "bun run tools/verify_slice1.ts",
    "verify:slice2": "bun run tools/verify_slice2.ts",
    "verify:slice3": "bun run tools/verify_slice3.ts",
    "verify:slice4": "bun run tools/verify_slice4.ts",
    "verify:slice5": "bun run tools/verify_slice5.ts",
    "verify:slice6": "bun run tools/verify_slice6.ts",
    "verify:slice7": "bun run tools/verify_slice7.ts",
    "verify:slice8": "bun run tools/verify_slice8.ts",
    "verify:slice9": "bun run tools/verify_slice9.ts",
    "verify:slice10": "bun run tools/verify_slice10.ts",
    "verify:slice10:hermes": "MUSUBI_HERMES_COMMAND=\"/Users/zhangqianze/.local/bin/hermes -z\" MUSUBI_HERMES_PROMPT=\"Reply with exactly: hermes-runtime-ok\" MUSUBI_HERMES_EXPECT=\"hermes-runtime-ok\" bun run tools/verify_slice10.ts",
    "verify:slice11": "bun run tools/verify_slice11.ts",
    "verify:slice11:build": "cd server/workers && TMPDIR=\"../../.cache/tmp\" BUN_INSTALL_CACHE_DIR=\"../../.cache/bun\" bunx wrangler deploy --env=\"\" --dry-run --outdir ../../.cache/worker-build",
    "verify:slice11:local": "bun run tools/verify_slice11_hosted_local.ts",
    "verify:slice11:deployed": "bun run tools/verify_slice11_deployed.ts",
    "verify:slice12": "bun run tools/verify_slice12_codex.ts",
    "verify:slice12:runtime": "CODEX_COMMAND=\"/bin/echo codex-runtime-ok\" CODEX_EXPECT=\"codex-runtime-ok\" bun run tools/verify_slice12_codex.ts",
    "verify:slice12:deployed": "bun run tools/verify_slice12_codex_deployed.ts",
    "verify:slice13": "bun run tools/verify_slice13_runtime_hardening.ts",
    "verify:slice13:deployed": "bun run tools/verify_slice13_runtime_hardening_deployed.ts",
    "verify:m2-control-plane": "bun run tools/verify_m2_control_plane.ts",
    "verify:m2.5-codex": "bun run tools/verify_m2_5_codex_adapter.ts",
    "verify:m3-app-sdk": "bun run tools/verify_m3_app_sdk.ts",
    "verify:m3.5-browser-session": "bun run tools/verify_m3_5_browser_session.ts",
    "verify:hermes-native-consent": "bun run tools/verify_hermes_native_consent.ts",
    "verify:user-admin-split": "bun run tools/verify_user_admin_split.ts",
    "verify:m4-platform-trust": "bun run tools/verify_m4_platform_trust.ts",
    "verify:m4-hosted-local": "bun run tools/verify_m4_hosted_local.ts",
    "verify:m4-hosted-deployed": "bun run tools/verify_m4_hosted_deployed.ts",
    "verify:control-plane:deployed": "bun run tools/verify_control_plane_deployed.ts",
    "verify:production-smoke": "bun run tools/verify_production_smoke.ts",
    "verify:m1-readiness": "bun run tools/verify_m1_readiness.ts"
  },
  "devDependencies": {},
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0"
  }
}
